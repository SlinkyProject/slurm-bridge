{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Controllers",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceRoot}/cmd/controllers/main.go",
      "args": [
        "--zap-log-level=5",
        "--config", "/tmp/config.yaml.debug"
      ],
      "preLaunchTask": "Setup Controllers",
      "envFile": "/tmp/slurm-bridge.env"
    },
    {
      "name": "Launch Admission",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceRoot}/cmd/admission/main.go",
      "args": [
        "--zap-log-level=5",
        "--config", "/tmp/config.yaml.debug"
      ],
      "preLaunchTask": "Setup Admission Debugging",
      "postDebugTask": "Revert Admission Debugging"
    },
    {
      "name": "Launch Scheduler",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceRoot}/cmd/scheduler/main.go",
      "args": [
        "--v=5",
        "--feature-gates=DRAExtendedResource=true,DynamicResourceAllocation=true,SchedulerPopFromBackoffQ=false",
        "--config", "/tmp/scheduler-config.yaml.debug"
      ],
      "preLaunchTask": "Setup Scheduler",
      "envFile": "/tmp/slurm-bridge.env"
    }
  ]
}
