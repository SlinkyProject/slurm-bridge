manifests should match snapshot:
  1: |
    apiVersion: v1
    data:
      scheduler-config.yaml: |
        apiVersion: kubescheduler.config.k8s.io/v1
        kind: KubeSchedulerConfiguration
        leaderElection:
          leaderElect: false
          resourceNamespace: test-namespace
          resourceName: slurm-bridge-scheduler
        profiles:
        - schedulerName: slurm-bridge-scheduler
          plugins:
            queueSort:
              enabled:
              - name: 'PrioritySort'
            preEnqueue:
              enabled:
              - name: 'SlurmBridge'
            preFilter:
              enabled:
              - name: 'VolumeBinding'
              - name: 'NodeResourcesFit'
              - name: 'SlurmBridge'
            filter:
              enabled:
              - name: 'VolumeBinding'
              - name: 'TaintToleration'
              - name: 'NodeResourcesFit'
              - name: 'SlurmBridge'
            postFilter:
              enabled:
              - name: 'SlurmBridge'
            reserve:
              enabled:
              - name: 'VolumeBinding'
            preBind:
              enabled:
              - name: 'VolumeBinding'
              - name: 'SlurmBridge'
            bind:
              enabled:
              - name: 'DefaultBinder'
            multiPoint:
              disabled:
              - name: '*'
          pluginConfig:
          - name: SlurmBridge
    kind: ConfigMap
    metadata:
      name: scheduler-config
      namespace: test-namespace
  2: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/component: scheduler
        app.kubernetes.io/instance: test-release
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: slurm-bridge-scheduler
        app.kubernetes.io/version: 1.2.3
        helm.sh/chart: slurm-bridge-1.2.3
      name: slurm-bridge-scheduler
      namespace: test-namespace
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/instance: test-release
          app.kubernetes.io/name: slurm-bridge-scheduler
      template:
        metadata:
          labels:
            app.kubernetes.io/component: scheduler
            app.kubernetes.io/instance: test-release
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: slurm-bridge-scheduler
            app.kubernetes.io/version: 1.2.3
            helm.sh/chart: slurm-bridge-1.2.3
        spec:
          containers:
            - args:
                - --config=/etc/kubernetes/scheduler-config.yaml
                - --feature-gates=DRAExtendedResource=true,DynamicResourceAllocation=true
              env:
                - name: SLURM_JWT
                  valueFrom:
                    secretKeyRef:
                      key: auth-token
                      name: slurm-bridge-token
              image: ghcr.io/slinkyproject/slurm-bridge-scheduler:1.2.3
              imagePullPolicy: IfNotPresent
              livenessProbe:
                httpGet:
                  path: /healthz
                  port: 10259
                  scheme: HTTPS
                initialDelaySeconds: 15
              name: scheduler
              readinessProbe:
                httpGet:
                  path: /healthz
                  port: 10259
                  scheme: HTTPS
              securityContext:
                privileged: false
              volumeMounts:
                - mountPath: /etc/kubernetes
                  name: scheduler-config
                  readOnly: true
                - mountPath: /etc/slurm-bridge/
                  name: slurm-bridge-config
                  readOnly: true
          hostNetwork: false
          hostPID: false
          serviceAccountName: slurm-bridge-scheduler
          volumes:
            - configMap:
                name: scheduler-config
              name: scheduler-config
            - configMap:
                name: slurm-bridge-config
              name: slurm-bridge-config
