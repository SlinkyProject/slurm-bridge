manifests should match snapshot:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/component: admission
        app.kubernetes.io/instance: test-release
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: slurm-bridge-admission
        app.kubernetes.io/version: 1.2.3
        helm.sh/chart: slurm-bridge-1.2.3
      name: slurm-bridge-admission
      namespace: test-namespace
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/instance: test-release
          app.kubernetes.io/name: slurm-bridge-admission
      template:
        metadata:
          annotations:
            checksum/config: e52364aa50203cb6d54d245f9245986ec8c42fb8d70382ecdac7012ab7cd2b63
          labels:
            app.kubernetes.io/component: admission
            app.kubernetes.io/instance: test-release
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: slurm-bridge-admission
            app.kubernetes.io/version: 1.2.3
            helm.sh/chart: slurm-bridge-1.2.3
        spec:
          containers:
            - env:
                - name: SLURM_JWT
                  valueFrom:
                    secretKeyRef:
                      key: auth-token
                      name: slurm-bridge-token
              image: ghcr.io/slinkyproject/slurm-bridge-admission:1.2.3
              imagePullPolicy: IfNotPresent
              livenessProbe:
                httpGet:
                  path: /healthz
                  port: 8081
                initialDelaySeconds: 15
              name: slurm-bridge-admission
              readinessProbe:
                httpGet:
                  path: /readyz
                  port: 8081
              volumeMounts:
                - mountPath: /tmp/k8s-webhook-server/serving-certs/
                  name: certificates
                  readOnly: true
                - mountPath: /etc/slurm-bridge/
                  name: slurm-bridge-config
                  readOnly: true
          serviceAccountName: slurm-bridge-admission
          volumes:
            - name: certificates
              secret:
                defaultMode: 420
                secretName: slurm-bridge-admission
            - configMap:
                name: slurm-bridge-config
              name: slurm-bridge-config
  2: |
    apiVersion: v1
    kind: ServiceAccount
    metadata:
      labels:
        app.kubernetes.io/component: admission
        app.kubernetes.io/instance: test-release
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: slurm-bridge-admission
        app.kubernetes.io/version: 1.2.3
        helm.sh/chart: slurm-bridge-1.2.3
      name: slurm-bridge-admission
      namespace: test-namespace
  3: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      name: slurm-bridge-admission
      namespace: test-namespace
    rules:
      - apiGroups:
          - ""
        resources:
          - namespaces
        verbs:
          - get
          - list
          - watch
  4: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRoleBinding
    metadata:
      labels:
        app.kubernetes.io/component: admission
        app.kubernetes.io/instance: test-release
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: slurm-bridge-admission
        app.kubernetes.io/version: 1.2.3
        helm.sh/chart: slurm-bridge-1.2.3
      name: slurm-bridge-admission
    roleRef:
      apiGroup: rbac.authorization.k8s.io
      kind: ClusterRole
      name: slurm-bridge-admission
    subjects:
      - kind: ServiceAccount
        name: slurm-bridge-admission
        namespace: test-namespace
  5: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/component: admission
        app.kubernetes.io/instance: test-release
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: slurm-bridge-admission
        app.kubernetes.io/version: 1.2.3
        helm.sh/chart: slurm-bridge-1.2.3
      name: slurm-bridge-admission
      namespace: test-namespace
    spec:
      ports:
        - name: https
          port: 443
          protocol: TCP
          targetPort: 9443
        - name: health
          port: 8081
          protocol: TCP
          targetPort: 8081
      selector:
        app.kubernetes.io/instance: test-release
        app.kubernetes.io/name: slurm-bridge-admission
      type: ClusterIP
  6: |
    apiVersion: admissionregistration.k8s.io/v1
    kind: ValidatingWebhookConfiguration
    metadata:
      annotations:
        cert-manager.io/inject-ca-from: test-namespace/slurm-bridge-admission
        certmanager.k8s.io/inject-ca-from: test-namespace/slurm-bridge-admission
      labels:
        app.kubernetes.io/component: admission
        app.kubernetes.io/instance: test-release
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: slurm-bridge-admission
        app.kubernetes.io/version: 1.2.3
        helm.sh/chart: slurm-bridge-1.2.3
      name: slurm-bridge-admission
    webhooks:
      - admissionReviewVersions:
          - v1
        clientConfig:
          service:
            name: slurm-bridge-admission
            namespace: test-namespace
            path: /validate--v1-pod
        name: pods.slinky.slurm.net
        namespaceSelector:
          matchExpressions:
            - key: kubernetes.io/metadata.name
              operator: NotIn
              values:
                - kube-system
                - test-namespace
        rules:
          - apiGroups:
              - ""
            apiVersions:
              - v1
            operations:
              - CREATE
              - UPDATE
            resources:
              - pods
              - pods/resize
            scope: Namespaced
        sideEffects: None
  7: |
    apiVersion: admissionregistration.k8s.io/v1
    kind: MutatingWebhookConfiguration
    metadata:
      annotations:
        cert-manager.io/inject-ca-from: test-namespace/slurm-bridge-admission
        certmanager.k8s.io/inject-ca-from: test-namespace/slurm-bridge-admission
      labels:
        app.kubernetes.io/component: admission
        app.kubernetes.io/instance: test-release
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: slurm-bridge-admission
        app.kubernetes.io/version: 1.2.3
        helm.sh/chart: slurm-bridge-1.2.3
      name: slurm-bridge-admission
    webhooks:
      - admissionReviewVersions:
          - v1
        clientConfig:
          service:
            name: slurm-bridge-admission
            namespace: test-namespace
            path: /mutate--v1-pod
        name: pods.slinky.slurm.net
        namespaceSelector:
          matchExpressions:
            - key: kubernetes.io/metadata.name
              operator: NotIn
              values:
                - kube-system
                - test-namespace
        rules:
          - apiGroups:
              - ""
            apiVersions:
              - v1
            operations:
              - CREATE
              - UPDATE
            resources:
              - pods
            scope: Namespaced
        sideEffects: None
  8: |
    apiVersion: v1
    data:
      config.yaml: |
        schedulerName: slurm-bridge-scheduler
        slurmRestApi: http://slurm-restapi.slurm:6820
        managedNamespaces:
          - slurm-bridge
        mcsLabel: kubernetes
        partition: slurm-bridge
    kind: ConfigMap
    metadata:
      labels:
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/version: 1.2.3
        helm.sh/chart: slurm-bridge-1.2.3
      name: slurm-bridge-config
      namespace: test-namespace
